# ─────────────────────────────────────────────────────────────────────────────
# Cloud Cost Analyzer — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Flask ────────────────────────────────────────────────────────────────────
FLASK_SECRET_KEY=change-me-to-a-long-random-string
# FLASK_THREADED=false

# ── Admin credentials ────────────────────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# ── Azure (Service Principal) ────────────────────────────────────────────────
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_SUBSCRIPTION_ID=

# ── GCP ──────────────────────────────────────────────────────────────────────
# GOOGLE_APPLICATION_CREDENTIALS=/app/gcp-key.json

# ── Database ─────────────────────────────────────────────────────────────────
DB_PATH=/app/data/azure_costs.db

# ── Cost sync ────────────────────────────────────────────────────────────────
COST_HISTORY_MONTHS=12
AUTO_SYNC_ENABLED=true
AUTO_SYNC_INTERVAL_HOURS=6

# ── Activity sync ────────────────────────────────────────────────────────────
ACTIVITY_AUTO_SYNC_ENABLED=false
ACTIVITY_AUTO_SYNC_INTERVAL_MINUTES=60
ACTIVITY_AUTO_SYNC_DAYS=7

# ── VM / threading (tune for small EC2 instances) ────────────────────────────
# SYNC_SEQUENTIAL=true
# FORCE_SYNC_INLINE=true
# SYNC_SUBPROCESS=true
# SYNC_INLINE_MODE=false
# ACTIVITY_SYNC_SUBPROCESS=true
# ACTIVITY_SYNC_INLINE_MODE=false

# ── Email / SMTP ─────────────────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@yourdomain.com
SMTP_USE_TLS=true

# ── AI Chatbot (Ollama — optional) ───────────────────────────────────────────
OLLAMA_ENABLED=false
OLLAMA_MODEL=qwen2.5:1.5b
# OLLAMA_HOST=http://localhost:11434
